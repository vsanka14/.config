#!/bin/bash
#
# rdev-url — print the rdev Server URL for the current directory.
#
# Looks up the mutagen sync whose Alpha URL is an ancestor of $PWD,
# derives the rdev name from the Beta host, then prints that rdev's
# Server URL from `rdev ls -a`.
#
# Usage:
#   rdev-url           # print URL
#   rdev-url -v        # print "<rdev-name>\t<url>"
#   rdev-url --open    # open URL in browser
#

set -euo pipefail

mode="url"
case "${1:-}" in
    -v|--verbose) mode="verbose" ;;
    --open)       mode="open" ;;
    -h|--help)
        sed -n '3,12p' "$0" | sed 's/^# \{0,1\}//'
        exit 0
        ;;
esac

pwd_dir="$(pwd -P)"

# Find Beta host from the first sync whose Alpha URL is a prefix of $PWD.
beta_host=$(mutagen sync list 2>/dev/null | awk -v pwd="${pwd_dir}/" '
    /^Alpha:/  { in_alpha=1; in_beta=0; next }
    /^Beta:/   { in_alpha=0; in_beta=1; next }
    /^Status:/ { in_alpha=0; in_beta=0; next }
    $1 == "URL:" {
        url = $2
        if (in_alpha) {
            alpha_url = url
        } else if (in_beta && alpha_url != "") {
            if (index(pwd, alpha_url "/") == 1) {
                colon = index(url, ":")
                if (colon > 0) {
                    print substr(url, 1, colon - 1)
                    exit
                }
            }
        }
    }
')

if [[ -z "$beta_host" ]]; then
    echo "rdev-url: no mutagen sync found covering $pwd_dir" >&2
    exit 1
fi

# Beta host is "<repo>_<rdev-suffix>"; rdev names join them with "/".
rdev_name="${beta_host%_*}/${beta_host##*_}"

url=$(rdev ls -a 2>/dev/null | awk -F'|' -v target="$rdev_name" '
    {
        name = $1; gsub(/^[[:space:]]+|[[:space:]]+$/, "", name)
        if (name == target) {
            u = $6; gsub(/^[[:space:]]+|[[:space:]]+$/, "", u)
            print u
            exit
        }
    }
')

if [[ -z "$url" ]]; then
    echo "rdev-url: no Server URL for rdev '$rdev_name' (not running?)" >&2
    exit 1
fi

case "$mode" in
    verbose) printf '%s\t%s\n' "$rdev_name" "$url" ;;
    open)    open "$url" ;;
    *)       echo "$url" ;;
esac
